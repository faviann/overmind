# Required: use an immutable release tag (there is no latest fallback).
OVERMIND_VERSION=<REPLACE_WITH_IMMUTABLE_RELEASE_VERSION>
POSTGRES_ADMIN_PASSWORD=<REPLACE_WITH_ADMIN_PASSWORD>
MEMSRV_PASSWORD=<REPLACE_WITH_RUNTIME_PASSWORD>

# Safe non-secret defaults shown explicitly for downstream translation.
OVERMIND_HTTP_BIND=0.0.0.0
OVERMIND_HTTP_PORT=8080
OVERMIND_AGENT_KEYS_FILE=./agent-keys.yaml
MEMSRV_AGENT_KEYS_PATH=/run/secrets/agent-keys.yaml
